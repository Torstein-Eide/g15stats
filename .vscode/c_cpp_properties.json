{
    "version": 4,
    "configurations": [
        {
            "name": "Linux",
            "compilerPath": "/usr/bin/gcc",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "gnu99",
            "defines": [
                "_GNU_SOURCE=1",
                "HAVE_CONFIG_H"
            ],
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/.",
                "/usr/include",
                "/usr/include/libgtop-2.0",
                "/usr/include/glib-2.0",
                "/usr/lib/x86_64-linux-gnu/glib-2.0/include",
                "/usr/include/sysprof-6"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "/usr/include",
                    "/usr/include/libgtop-2.0",
                    "/usr/include/glib-2.0",
                    "/usr/lib/x86_64-linux-gnu/glib-2.0/include",
                    "/usr/include/sysprof-6"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
